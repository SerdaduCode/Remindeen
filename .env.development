# Overrides for `wxt dev` only — points Kanban/Habit API calls at a locally
# running al-quotes server (npm run dev, port 3000) instead of prod.
# Loaded automatically by Vite only in development mode; prod builds use
# the values in .env.local unaffected.
VITE_API_TASKS="http://localhost:3000/tasks"
VITE_API_HABITS="http://localhost:3000/habits"
